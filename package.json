{
  "name": "dotnetfinal",
  "version": "0.0.0",
  "private": true,
  "description": "Description for Dotnetfinal",
  "license": "UNLICENSED",
  "workspaces": [
    "src/Dotnetfinal/ClientApp"
  ],
  "scripts": {
    "app:up": "docker compose -f docker/app.yml up --wait",
    "ci:e2e:prepare": "npm run ci:e2e:prepare:docker",
    "ci:e2e:prepare:docker": "npm run services:up --if-present && docker ps -a",
    "ci:e2e:run": "concurrently -k -s first \"npm run ci:e2e:server:start\" \"npm run e2e:headless\"",
    "ci:e2e:server:start": "docker compose -f docker/app.yml up --wait",
    "ci:e2e:teardown": "npm run ci:e2e:teardown:docker --if-present",
    "ci:e2e:teardown:docker": "docker compose -f docker/services.yml down -v && docker ps -a",
    "ci:frontend:test": "npm run -w src/Dotnetfinal/ClientApp/ ci:frontend:test",
    "docker:db:up": "echo \"Docker for db sqllite not configured for application dotnetfinal\"",
    "docker:keycloak:down": "docker compose -f docker/keycloak.yml down -v",
    "docker:keycloak:up": "docker compose -f docker/keycloak.yml up --wait",
    "prettier:check": "prettier --check \"{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,js,cjs,mjs,ts,cts,mts,html,tsx,css,scss}\"",
    "prettier:format": "prettier --write \"{,src/**/,webpack/,.blueprint/**/}*.{md,json,yml,js,cjs,mjs,ts,cts,mts,html,tsx,css,scss}\"",
    "services:up": "docker compose -f docker/services.yml up --wait",
    "test": "npm test -w src/Dotnetfinal/ClientApp/",
    "webapp:build": "npm run -w src/Dotnetfinal/ClientApp/ webapp:build"
  },
  "config": {
    "default_environment": "prod"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "9.1.2",
    "generator-jhipster": "8.10.0",
    "generator-jhipster-dotnetcore": "4.5.0",
    "prettier": "3.5.3",
    "prettier-plugin-packagejson": "2.5.10"
  },
  "engines": {},
  "overrides": {
    "browser-sync": "3.0.3"
  }
}
