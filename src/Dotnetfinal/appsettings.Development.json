{
  "Serilog": {
    "MinimumLevel": "Debug",
    "SyslogUrl": "localhost",
    "SyslogPort": "6514",
    "SyslogAppName": "dotnetfinal",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u4} {ProcessId} --- [{ThreadId,3}] {LoggerName,-40} : {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "EntityFramework": {
    "DataSource": ":memory:"
  },
  "Security": {
    "EnforceHttps": true,
    "Email": {
      "From": "noreply@dotnetfinal.com",
      "BaseUrl": "https://dotnetfinal.com",
      "Smtp": {
        "Host": "smtp.dotnetfinal.com",
        "Port": 587,
        "Username": "",
        "Password": "",
        "UseSsl": true
      }
    }
  }
}
