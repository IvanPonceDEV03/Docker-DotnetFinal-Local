{
  "Serilog": {
    "MinimumLevel": "Information",
    "SyslogUrl": "localhost",
    "SyslogPort": "6514",
    "SyslogAppName": "dotnetfinal",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u4} {ProcessId} --- [{ThreadId,3}] {LoggerName,-40} : {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "app.log",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u4} {ProcessId} --- [{ThreadId,3}] {LoggerName,-40} : {Message:lj}{NewLine}{Exception}",
          "fileSizeLimitBytes": 10240,
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90
        }
      }
    ]
  },
  "EntityFramework": {
    "DataSource": "Server=mssql,1433;Database=AppDotnet;User Id=sa;Password=DoRe34/26C7;TrustServerCertificate=True;Encrypt=False"
  },
  "Security": {
    "EnforceHttps": true,
    "Email": {
      "From": "noreply@dotnetfinal.com",
      "BaseUrl": "https://dotnetfinal.com",
      "Smtp": {
        "Host": "smtp.dotnetfinal.com",
        "Port": 587,
        "Username": "",
        "Password": "",
        "UseSsl": true
      }
    },
    "Authentication": {
      "OAuth2": {
        "Provider": {
          "IssuerUri": "http://keycloak:9080/realms/jhipster",
          "LogOutUri": "http://keycloak:9080/realms/jhipster/protocol/openid-connect/logout",
          "ClientId": "web_app",
          "ClientSecret": "web_app"
        }
      }
    }
  }
}
